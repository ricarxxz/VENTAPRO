{
  "builds": [
    {
      "src": "backend/api_handler.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/",
      "dest": "backend/api_handler.py"
    },
    {
      "src": "/admin/",
      "dest": "backend/api_handler.py"
    },
    {
      "src": "/static/",
      "dest": "backend/api_handler.py"
    },
    {
      "src": "/manifest.webmanifest",
      "dest": "frontend/manifest.webmanifest"
    },
    {
      "src": "/sw.js",
      "dest": "frontend/sw.js"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/index.html"
    }
  ]
}