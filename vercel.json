{
  "framework": null,
  "builds": [
    {
      "src": "backend/vercel_app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/backend/vercel_app.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/backend/vercel_app.py"
    }
  ]
}