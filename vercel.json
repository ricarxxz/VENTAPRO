{
  "builds": [
    {
      "src": "backend/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "frontend/**",
          "backend/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/index.py"
    },
    {
      "src": "/auth/(.*)",
      "dest": "/backend/index.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/backend/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/backend/index.py"
    }
  ]
}