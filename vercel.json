{
  "builds": [
    {
      "src": "backend/vercel_app.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/vercel_app.py"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/backend/vercel_app.py"
    },
    {
      "source": "/manifest.webmanifest",
      "destination": "/frontend/manifest.webmanifest"
    },
    {
      "source": "/sw.js",
      "destination": "/frontend/sw.js"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/index.html"
    }
  ]
}